#. Description of the plugin
#: braves_chat.php
msgid ""
"A professional tool that connects your website to your N8N agent, allowing "
"you to provide AI-powered support directly on your website."
msgstr ""
"Una herramienta profesional que conecta tu sitio web con tu agente de N8N, "
"lo que te permite ofrecer asistencia basada en inteligencia artificial "
"directamente en tu sitio web."

#. Author of the plugin
#: braves_chat.php
msgid "Carlos Vera"
msgstr "Carlos Vera"

#. Author URI of the plugin
